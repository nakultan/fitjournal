# Copy to `.env.local` and fill in from Supabase → Project Settings → Data API.
# Both values are the public anon key + URL — safe to expose in a browser
# build (Row-Level Security protects the data). Do NOT use the service_role key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: enables the closed-app streak-save reminder via Web Push.
# Generate with `npx web-push generate-vapid-keys` and keep the *private*
# key out of this file — it belongs in Supabase function secrets.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
